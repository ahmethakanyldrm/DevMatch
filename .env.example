# -----------------------------------------------------------------------------
# TechConnect - Local Environment Variables Template
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT commit '.env' to git!
# -----------------------------------------------------------------------------

# 1. Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/techconnect
DB_USERNAME=postgres
DB_PASSWORD=postgres

# 2. Authentication Configuration (JWT & OAuth)
JWT_SECRET=your_super_secret_jwt_key_at_least_256_bits_long
APPLE_CLIENT_ID=your_apple_client_id
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# 3. Storage Configuration (Cloudflare R2 / S3-compatible)
CLOUDFLARE_R2_ACCESS_KEY=your_cloudflare_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_cloudflare_r2_secret_key
CLOUDFLARE_R2_BUCKET_NAME=techconnect-assets
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# 4. Subscription Configuration (RevenueCat)
REVENUECAT_API_KEY=your_revenuecat_api_key

# 5. Push Notifications (Firebase Cloud Messaging)
FCM_SERVER_KEY=your_fcm_server_key
GOOGLE_APPLICATION_CREDENTIALS=config/firebase-service-account.json
